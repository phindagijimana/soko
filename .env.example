APP_NAME=Agri Marketplace API
ENVIRONMENT=development
DEBUG=true
SECRET_KEY=change-me-in-production
DATABASE_URL=sqlite:///./agri_marketplace.db
# Default in code includes 5173 and 2000-2050 for local UI; override only if needed.
ALLOWED_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
TRUSTED_HOSTS=127.0.0.1,localhost,testserver
# file | console | twilio — twilio uses Twilio REST when TWILIO_ACCOUNT_SID starts with AC and token is set
SMS_PROVIDER=file
SMS_LOG_PATH=./sms_log.txt
TWILIO_ACCOUNT_SID=placeholder
TWILIO_AUTH_TOKEN=placeholder
TWILIO_FROM_PHONE=+10000000000
# Optional Twilio status callback URL (omit or leave placeholder if unused)
SMS_STATUS_CALLBACK_URL=placeholder
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=5
OTP_MAX_ATTEMPTS=5
OTP_LOCKOUT_MINUTES=15
OTP_RESEND_COOLDOWN_SECONDS=30
AUTH_TOKEN_HOURS=24
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_MAX_REQUESTS=30
AUTH_RATE_LIMIT_MAX_REQUESTS=8
UPLOAD_RATE_LIMIT_MAX_REQUESTS=12
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_BYTES=2097152
MAX_IMAGE_COUNT_PER_LISTING=3
ENABLE_SEED_DATA=true
ADMIN_PHONE_NUMBERS=+250700000001
SUPPORT_EMAIL=support@example.com

# DB: set false when using Alembic only (e.g. Docker)
CREATE_TABLES_ON_STARTUP=true

# Storage: local | s3 (requires bucket + MEDIA_PUBLIC_BASE_URL)
STORAGE_BACKEND=local
S3_BUCKET_NAME=
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_ENDPOINT_URL=
MEDIA_PUBLIC_BASE_URL=

# Optional error monitoring
SENTRY_DSN=
